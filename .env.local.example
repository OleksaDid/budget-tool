# Tink API Configuration
# These variables are server-side only and will not be exposed to the client

# Your Tink API Credentials (get from Tink Console)
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=

# Redirect URI (must match in Tink Console)
TINK_REDIRECT_URI=http://localhost:3000/callback

# API URL (default is already set)
TINK_API_URL=https://api.tink.com

# ActivoBank Provider ID
ACTIVO_BANK_PROVIDER_ID=activobank-pt

# Public environment variables (will be exposed to the client)
NEXT_PUBLIC_APP_NAME=Budget Tool 